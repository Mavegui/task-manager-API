#Don't use spaces in the environment variables!!!!!!!!!

SECRET_KEY='secret-key-here'
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1-or-production-url
DATABASE_URL=db-used

#JWT 
JWT_SIGNING_KEY=your-signing-generated
JWT_ACCESS_LIFETIME_MINUTES=time-your-choice-example-60
JWT_REFRESH_LIFETIME_DAYS=days-your-choice-example-7

#CORS-HEADERS
CORS_ALLOWED_ORIGINS_PROD=Url-do-site-em-produção

#DATABASE CONFIG'S 
#SEPARATE FIELD's or use DATABASE_URL...
# Confirm that the data is the same as those used in the docker
DB_NAME=database-name-here
DB_USER=database-user-here(Example:admin)
DB_PASSWORD=your-password-here
DB_HOST=db
DB_PORT=5432